rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ALMUSTASHARAI SECURITY RULES - PRODUCTION READY
     * 
     * هويتنا: السيطرة الكاملة للمالك والحماية التامة للمستخدم.
     * المالك: bishoysamy390@gmail.com
     */

    // --- وظائف المساعدة ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** التحقق من هوية المالك (بيشوي سامي) عبر البريد الإلكتروني */
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "bishoysamy390@gmail.com";
    }

    // --- قوانين المجموعات ---

    /** إدارة الأدوار - للمالك فقط */
    match /roles_admin/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list, write: if isAdmin();
    }

    /** بيانات المستخدمين */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      // المالك فقط يمكنه تعديل الرصيد (balance) في العمليات الحساسة
      allow update: if (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['balance', 'status'])) || isAdmin();
      allow delete: if isAdmin();

      /** طلبات الاستشارة الخاصة */
      match /consultationRequests/{requestId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update, delete: if isOwner(userId) || isAdmin();
      }
    }

    /** التخصصات القانونية - قراءة للجميع، تعديل للمالك */
    match /specializations/{specializationId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    /** ملفات المستشارين - قراءة للجميع، تعديل للمالك أو صاحب الملف */
    match /consultantProfiles/{consultantId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if (resource != null && resource.data.userId == request.auth.uid) || isAdmin();
      allow delete: if isAdmin();
    }

    /** الجلسات والاستشارات - للطرفين المشاركين وللمالك */
    match /consultations/{consultationId} {
      allow get: if (resource.data.userId == request.auth.uid || resource.data.consultantId == request.auth.uid) || isAdmin();
      allow list: if isSignedIn(); // الفلترة تتم برمجياً
      allow create: if isSignedIn();
      allow update: if (resource.data.userId == request.auth.uid || resource.data.consultantId == request.auth.uid) || isAdmin();
      allow delete: if isAdmin();
    }
    
    /** طلبات شحن الرصيد */
    match /paymentRequests/{requestId} {
      allow get: if (resource.data.userId == request.auth.uid) || isAdmin();
      allow list: if isAdmin() || (isSignedIn() && request.query.limit <= 20); 
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}